// Schema do Bloco 0 — Fundação. Alinhado a docs/04-data-model.md.
// Entidades de blocos posteriores (Order, Conversation, Review, Report,
// BusinessListing) serão adicionadas nos respectivos blocos.

generator client {
  provider      = "prisma-client-js"
  // native = dev local; rhel = runtime serverless da Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  // relationJoins: carrega relações via LATERAL JOIN (1 query) em vez de N
  // round-trips — crítico com o banco em outra região. Ativa por query com
  // relationLoadStrategy: 'join'.
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL = conexão "pooled" do Supabase (pgbouncer, porta 6543) — usada em runtime.
  // DIRECT_URL   = conexão direta (porta 5432) — usada por migrate/introspect.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  individual
  business
}

enum UserStatus {
  active
  blocked
}

enum ListingStatus {
  draft
  active
  paused
  sold
  archived
}

enum EmailTokenPurpose {
  verify
  recovery
}

model User {
  id              String     @id @default(uuid())
  name            String
  lastName        String? // sobrenome (coletado no cadastro; legados ficam null)
  spot            String? // spot de interesse (lista controlada SPOTS) — perfil
  email           String?    @unique // opcional no cadastro; pedido depois
  emailVerified   Boolean    @default(false)
  sessionVersion  Int        @default(0) // incrementa em recuperação; invalida sessões antigas
  phone           String     @unique
  phoneCountry    String     @default("BR")
  phoneVerified   Boolean    @default(false) // nível 1 — antifake (OTP)
  locale          String     @default("pt")
  country         String?
  avatarUrl       String? // obrigatório no onboarding (regra de app, não de banco)
  instagramHandle String? // prova social — exibido
  cpf             String? // nullable; só vendedor BR com payout PIX
  payoutAccountId String? // id da conta no PSP
  role            UserRole   @default(individual)
  status          UserStatus @default(active)
  admin           Boolean    @default(false) // acesso à moderação (/moderacao)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  listings  Listing[]
  favorites Favorite[]

  sentRequests     Request[] @relation("buyerRequests")
  receivedRequests Request[] @relation("sellerRequests")

  buyerConversations  Conversation[] @relation("buyerConvos")
  sellerConversations Conversation[] @relation("sellerConvos")
  messages            Message[]

  sellerDeals     Deal[]   @relation("sellerDeals")
  buyerDeals      Deal[]   @relation("buyerDeals")
  reviewsGiven    Review[] @relation("reviewsGiven")
  reviewsReceived Review[] @relation("reviewsReceived")
  reportsMade     Report[] @relation("reportsMade")

  notifications Notification[] @relation("userNotifications")
  emailTokens   EmailToken[]
  moderationActions ModerationAction[] @relation("moderationActions") // ações que ESTE admin tomou
  disputesOpened   DealDispute[] @relation("disputesOpened")
  disputesAgainst  DealDispute[] @relation("disputesAgainst")
  disputesResolved DealDispute[] @relation("disputesResolved")

  @@index([phone])
}

// Código OTP — DOIS canais: SMS (phone) ou e-mail. Mata o SPOF do Twilio (queda
// total = todo login bloqueado). Exatamente UM dos dois (phone/email) deve estar
// preenchido por linha. Cadastro novo ainda exige telefone — email só serve pra
// login/recuperação de quem JÁ tem e-mail verificado na conta.
model OtpCode {
  id        String   @id @default(uuid())
  phone     String?  // SMS via Twilio
  email     String?  // E-mail via Resend (fallback do SPOF)
  codeHash  String   // nunca guardamos o código em texto puro
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  context   String   @default("login") // isola login de troca/recuperação de telefone
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([phone, context])
  @@index([email, context])
}

// Link de verificação/recuperação enviado por e-mail. Só o hash do token é salvo.
model EmailToken {
  id         String            @id @default(uuid())
  userId     String
  email      String
  purpose    EmailTokenPurpose
  tokenHash  String            @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([email, purpose])
}

// Define quais atributos cada categoria exige (kite -> size_m2, ano; etc.)
model Category {
  id              String   @id @default(uuid())
  slug            String   @unique
  namePt          String
  nameEn          String
  attributeSchema Json // JSON Schema dos atributos obrigatórios
  active          Boolean  @default(true) // false = fora do MVP (não aparece no anunciar)
  createdAt       DateTime @default(now())

  models   Model[]
  listings Listing[]
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  models   Model[]
  listings Listing[] @relation("ListingBrand")
  barraListings Listing[] @relation("ListingBarraBrand")
}

model Model {
  id         String   @id @default(uuid())
  name       String
  brandId    String
  categoryId String?
  createdAt  DateTime @default(now())

  brand    Brand     @relation(fields: [brandId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  listings Listing[] @relation("ListingModel")
  barraListings Listing[] @relation("ListingBarraModel")

  @@unique([brandId, name])
}

model Listing {
  id              String        @id @default(uuid())
  userId          String
  categoryId      String
  brandId         String?
  modelId         String?
  barraBrandId    String?
  barraModelId    String?
  year            Int?
  barraYear       Int?
  attributes      Json          @default("{}") // validado contra Category.attributeSchema (peça primária)
  title           String
  description     String?
  price           Int // centavos — preço do CONJUNTO (kit) ou da peça única (kite-only/barra-only)
  // --- Kit (kite + barra no mesmo anúncio) ---
  hasBarra        Boolean       @default(false) // true = kit (categoria primária = kite; barra embutida)
  kitePrice       Int?          // centavos — kite avulso; null = não vendo o kite sozinho
  barraPrice      Int?          // centavos — barra avulsa; null = não vendo a barra sozinha
  barraAttributes Json?         // infos da barra do kit (line_length_m, condition); barra-only usa `attributes`
  city            String // spot principal (lista controlada — ex: Cumbuco, Taíba)
  spot            String? // ponto específico opcional (texto livre)
  pickup          Boolean       @default(true) // retirada no local
  shippable       Boolean       @default(false) // envio (Correios)
  status          ListingStatus @default(draft)
  soldToUserId    String?
  lastConfirmedAt DateTime?
  // venda por componente (kit): peça avulsa vendida (null = ainda disponível).
  kiteSoldAt        DateTime?
  kiteSoldToUserId  String?
  barraSoldAt       DateTime?
  barraSoldToUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  user          User           @relation(fields: [userId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  brand         Brand?         @relation("ListingBrand", fields: [brandId], references: [id])
  model         Model?         @relation("ListingModel", fields: [modelId], references: [id])
  barraBrand    Brand?         @relation("ListingBarraBrand", fields: [barraBrandId], references: [id])
  barraModel    Model?         @relation("ListingBarraModel", fields: [barraModelId], references: [id])
  images        ListingImage[]
  conversations Conversation[]
  deals         Deal[]
  favoritedBy   Favorite[]
  requests      Request[]

  @@index([userId]) // perfil, meus anúncios, ownership
  @@index([categoryId])
  @@index([barraBrandId])
  @@index([barraModelId])
  @@index([city])
  @@index([status, deletedAt]) // filtro base de toda busca (active + não-excluído)
  @@index([kiteSoldAt])
  @@index([barraSoldAt])
  @@index([attributes], type: Gin) // busca por tamanho etc.
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  url       String
  thumbUrl  String? // 400px — usado nos cards da busca; url (1600px) fica no detalhe
  component String? // 'kite' | 'barra' — qual peça do kit a foto mostra (null = anúncio de peça única)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

enum ConversationStatus {
  open
  archived
  blocked
}

// Conversa atrelada a um anúncio: 1 comprador + 1 vendedor.
model Conversation {
  id        String             @id @default(uuid())
  listingId String
  buyerId   String
  sellerId  String
  status    ConversationStatus @default(open)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("buyerConvos", fields: [buyerId], references: [id])
  seller   User      @relation("sellerConvos", fields: [sellerId], references: [id])
  messages Message[]
  deal     Deal?

  @@unique([listingId, buyerId]) // 1 conversa por comprador por anúncio
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  imageUrl       String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
}

enum DealStatus {
  seller_confirmed
  completed
  cancelled // desfeito pelo vendedor (cancelSale) ou pelo comprador ("não comprei")
  voided // invalidado: peça vendida a outro comprador / componente indisponível
  closed_unconfirmed // vendedor encerrou após 72h sem confirmação: vendido, mas não conta nem avalia
  reversal_requested // pós-completed: uma parte pediu correção, aguardando a outra
  reversed // correção aceita pelas duas partes: deixa de contar, peça volta a paused
  disputed // correção recusada: vai pra fila de disputa da moderação; segue vendido até decisão
}

enum DisputeStatus {
  open
  under_review
  resolved_upheld // admin mantém a venda
  resolved_reversed // admin reverte a venda → Deal reversed
  closed
}

enum DisputeReason {
  devolvido
  engano
  nao_aconteceu
  outro
}

// Qual peça de um kit está sendo negociada/vendida. Peça única / kite-only /
// barra-only usam sempre 'conjunto' (o anúncio inteiro).
enum Component {
  conjunto
  kite
  barra
}

// "Aperto de mão" sem dinheiro (Fase 0): vendedor confirma a venda escolhendo
// o comprador → comprador confirma a compra → vira `completed`, anúncio `sold`,
// e habilita avaliação dos dois lados.
model Deal {
  id                String     @id @default(uuid())
  listingId         String
  conversationId    String?    @unique
  sellerId          String
  buyerId           String
  status            DealStatus @default(seller_confirmed)
  component         Component  @default(conjunto) // qual peça do kit foi vendida
  sellerConfirmedAt    DateTime?
  buyerConfirmedAt     DateTime?
  confirmationDeadlineAt DateTime? // sellerConfirmedAt + 72h (gravado na confirmação)
  closedUnconfirmedAt  DateTime?
  reversalRequestedAt  DateTime?
  reversedAt           DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  listing      Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  seller       User          @relation("sellerDeals", fields: [sellerId], references: [id])
  buyer        User          @relation("buyerDeals", fields: [buyerId], references: [id])
  reviews      Review[]
  disputes     DealDispute[]

  @@index([sellerId])
  @@index([buyerId])
  @@index([status, confirmationDeadlineAt]) // cron das 72h varre seller_confirmed vencidos
  // Índices únicos PARCIAIS por (listingId, component), criados via SQL nas migrations
  // (Prisma não modela partial unique index):
  //  - status='completed'      → 1 venda completa por componente (component_sales)
  //  - status='seller_confirmed' → 1 reserva pendente por componente (negociacao_v2)
}

// Disputa de negócio (pós-completed): ciclo próprio, fila separada de Report.
model DealDispute {
  id                String        @id @default(uuid())
  dealId            String
  openedByUserId    String
  counterpartyId    String
  reason            DisputeReason
  description       String?
  status            DisputeStatus @default(open)
  resolution        String?
  resolvedByAdminId String?
  createdAt         DateTime      @default(now())
  resolvedAt        DateTime?

  deal            Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  openedBy        User  @relation("disputesOpened", fields: [openedByUserId], references: [id])
  counterparty    User  @relation("disputesAgainst", fields: [counterpartyId], references: [id])
  resolvedByAdmin User? @relation("disputesResolved", fields: [resolvedByAdminId], references: [id])

  @@index([status])
  @@index([dealId])
}

// Avaliação atrelada a um Deal `completed`. 1 review por avaliador por deal.
model Review {
  id         String   @id @default(uuid())
  dealId     String
  reviewerId String
  reviewedId String
  rating     Int // 1-5
  tags       String[] @default([]) // critérios padronizados marcados (ex: "Pontual")
  comment    String?
  createdAt  DateTime @default(now())

  deal     Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  reviewer User @relation("reviewsGiven", fields: [reviewerId], references: [id])
  reviewed User @relation("reviewsReceived", fields: [reviewedId], references: [id])

  @@unique([dealId, reviewerId])
  @@index([reviewedId])
}

// Rate limiting via banco (janela fixa). Sem infra nova; cron de limpeza no P2.
//
// bucketStart = epoch (segundos) do INÍCIO da janela à qual esta linha pertence.
// O caller calcula floor(now/windowSec)*windowSec, e o @@unique([key, bucketStart])
// garante upsert ATÔMICO: dois requests concorrentes na mesma janela disputam a
// mesma linha e `count` incrementa serializadamente — fim da race count+create.
model RateHit {
  id          String   @id @default(uuid())
  key         String
  bucketStart Int      @default(0)
  count       Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([key, bucketStart])
  @@index([key, createdAt])
}

enum ReportStatus {
  open
  reviewed
  actioned
}

// Denúncia → fila manual (admin via SQL no MVP). T&S essencial e barato.
model Report {
  id         String       @id @default(uuid())
  reporterId String
  targetType String // user | listing | message
  targetId   String
  reason     String
  status     ReportStatus @default(open)
  createdAt  DateTime     @default(now())

  reporter User @relation("reportsMade", fields: [reporterId], references: [id])
  actions  ModerationAction[] // trilha de ações tomadas a partir desta denúncia

  @@index([status])
}

// Ação de moderação executada por um admin (append-only) — trilha de auditoria.
enum ModerationActionType {
  suspend_user
  restore_user
  remove_listing
  restore_listing
}

model ModerationAction {
  id          String               @id @default(uuid())
  reportId    String? // a denúncia que originou a ação (opcional — pode ser ação avulsa)
  moderatorId String
  action      ModerationActionType
  targetType  String // user | listing
  targetId    String
  note        String? // observação livre do moderador
  createdAt   DateTime             @default(now())

  moderator User    @relation("moderationActions", fields: [moderatorId], references: [id])
  report    Report? @relation(fields: [reportId], references: [id])

  @@index([targetType, targetId])
  @@index([reportId])
  @@index([createdAt])
}

enum RequestType {
  offer
  visit
}

enum RequestStatus {
  pending
  accepted
  declined // recusado pelo vendedor
  withdrawn // retirado/encerrado pelo comprador (inclui "não comprei")
  listing_removed // anúncio excluído pelo dono
  sold_elsewhere // peça vendida a outro comprador
  expired // reservado: expiração ainda não implementada (sem job)
}

// Contato estruturado (substitui chat livre). Comprador faz oferta (valor) ou
// pede visita; vendedor aceita → libera o WhatsApp pro comprador.
model Request {
  id        String        @id @default(uuid())
  listingId String
  buyerId   String
  sellerId  String
  type      RequestType
  amount    Int? // centavos — só pra oferta
  status    RequestStatus @default(pending)
  component Component     @default(conjunto) // alvo da oferta/visita (peça do kit)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("buyerRequests", fields: [buyerId], references: [id])
  seller  User    @relation("sellerRequests", fields: [sellerId], references: [id])

  @@unique([listingId, buyerId, type, component]) // 1 oferta + 1 visita por comprador por peça
  @@index([sellerId])
  @@index([buyerId])
}

// Favorito — comprador salva um anúncio. 1 por par.
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

// Tipos de evento da notificação in-app (emissão no commit de notificações).
enum NotificationType {
  request_new // vendedor: novo pedido recebido
  request_accepted // comprador: vendedor liberou o WhatsApp
  request_declined // comprador: vendedor recusou
  sale_marked // comprador: vendedor marcou vendido — falta você confirmar
  purchase_confirmed // vendedor: comprador confirmou a compra
  purchase_denied // vendedor: comprador respondeu "não comprei"
  sold_elsewhere // comprador: a peça foi vendida a outra pessoa
  listing_removed // comprador: o anúncio foi removido
  sale_cancelled // comprador: o vendedor cancelou a venda marcada
  sale_closed_unconfirmed // comprador: o vendedor encerrou a venda após 72h sem confirmação
  reversal_requested // a outra parte pediu correção/devolução da venda
  reversal_confirmed // a correção foi aceita: venda revertida
  reversal_rejected // a correção foi recusada: virou disputa
}

// Auditoria de ações IRREVERSÍVEIS / financeiras (LGPD + disputa). Append-only.
// Escopo deliberadamente estreito no MVP: deleteAccount, confirmPurchase, troca de
// e-mail/telefone — NÃO é audit completo de toda mutação (isso vira tarefa pós-escala).
// `before`/`after` carregam só os campos relevantes da ação, NUNCA o objeto Prisma cru.
model AuditEvent {
  id            String   @id @default(uuid())
  actorUserId   String?  // quem executou; null pra ações do sistema (cron, etc)
  action        String   // account.delete | deal.confirm_purchase | user.email_changed | ...
  entityType    String   // user | deal | listing
  entityId      String
  before        Json?
  after         Json?
  correlationId String?  // backbone do Sprint 2
  ipHash        String?  // HMAC do IP (Sprint 2 também — pode ficar null por ora)
  userAgent     String?
  release       String?  // VERCEL_GIT_COMMIT_SHA do deploy que executou
  result        String   @default("ok") // ok | error
  createdAt     DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

// Execução de job (cron e on-demand). Sentinela de "rodou? quando? deu certo?".
// Vamos alertar via Sentry quando JobRun.findFirst({ status: ok, finishedAt > X horas })
// não voltar nada, OU quando há linha presa em status=running por > timeout.
model JobRun {
  id          String    @id @default(uuid())
  job         String    // cleanup | close-unconfirmed | ...
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    // running | ok | error
  result      Json?
  error       String?
  release     String?

  @@index([job, startedAt])
  @@index([status, startedAt])
}

// Notificação in-app persistente. `read` por readAt. Refs opcionais pro deep-link.
model Notification {
  id         String           @id @default(uuid())
  userId     String // destinatário
  type       NotificationType
  listingId  String?
  requestId  String?
  dealId     String?
  actorId    String? // quem disparou (outro lado da negociação)
  data       Json? // título/valor já resolvidos pra render sem N joins
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user User @relation("userNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Outbox de entrega externa (Twilio SMS/WhatsApp). Estratégia inline-first: o envio
// tenta INLINE no request; só quando FALHA (timeout/erro/Twilio fora) grava uma linha
// `pending` aqui, e o cron drain-notifications reenvia com backoff. Mata a perda
// silenciosa do fail-open antigo sem atrasar o caminho feliz por uma fila.
enum DeliveryStatus {
  pending
  sent
  failed
}

model NotificationDelivery {
  id            String         @id @default(uuid())
  channel       String // sms | whatsapp
  kind          String // new_request | accept — métrica/debug
  body          Json // params do POST Twilio (From/To/Body/ContentSid/...), pra reenviar idêntico
  status        DeliveryStatus @default(pending)
  attempts      Int            @default(0)
  lastError     String? // status/erro do último envio (sem PII)
  nextAttemptAt DateTime       @default(now())
  createdAt     DateTime       @default(now())
  sentAt        DateTime?

  @@index([status, nextAttemptAt]) // o drain varre pending vencidos
}
