# ----------------------------------------------------------------------------
# Kitetropos — variáveis de ambiente (apps/web)
# Copie para .env e preencha. NUNCA commite o .env preenchido.
# Cada AMBIENTE (prod / staging / preview) tem seu próprio conjunto de valores.
# Em especial: JWT_SECRET, DATABASE_URL e SUPABASE_* DEVEM diferir entre prod e staging.
# ----------------------------------------------------------------------------

# --- Banco (Supabase Postgres) ---
# Runtime: Transaction pooler (pgbouncer), porta 6543
DATABASE_URL=
# Migrations: Session pooler, porta 5432 (prisma migrate deploy usa esta)
DIRECT_URL=

# --- Storage / API do Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=listings

# --- Auth / API ---
API_PORT=3000
# >= 32 chars. O app TRAVA em prod sem isto. Use um valor DIFERENTE por ambiente.
JWT_SECRET=
JWT_EXPIRES_IN=7d
# OTP_MOCK=true só fora de prod (libera devCode / números de teste)
OTP_MOCK=
OTP_TTL_SECONDS=300
PSP_PROVIDER=mock

# --- SMS (Twilio) — setado na Vercel, não no .env local ---
# Em staging: usar números de teste / allowlist, nunca disparar pra usuário real.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Observabilidade (Sentry) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_DEV=true   # liga o Sentry em desenvolvimento
# CSP_REPORT_URI=   # endpoint "Security Header" do Sentry; liga report-uri/report-to da CSP
#   formato: https://oXXXX.ingest.sentry.io/api/<project-id>/security/?sentry_key=<public-key>

# --- App ---
# URL pública do ambiente (prod: https://kitetropos.com ; staging: https://staging.kitetropos.com)
APP_URL=
