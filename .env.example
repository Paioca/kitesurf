# ============================================================
#  API (apps/api/.env)  —  Supabase + Vercel
# ============================================================

# ---- Banco (Supabase) ----
# Supabase > Project Settings > Database > Connection string.
# DATABASE_URL = "Transaction pooler" (porta 6543, com ?pgbouncer=true) — runtime.
# DIRECT_URL   = "Direct connection" (porta 5432) — migrations.
DATABASE_URL="postgresql://postgres.PROJ:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJ:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# ---- Supabase Storage (imagens) ----
# Supabase > Project Settings > API.
SUPABASE_URL="https://PROJ.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."   # SECRETO — só no backend
SUPABASE_BUCKET="listings"                          # crie um bucket PÚBLICO com esse nome

# ---- API ----
API_PORT=3001
JWT_SECRET="troque-isto-por-um-segredo-forte"
JWT_EXPIRES_IN="30d"

# ---- OTP / SMS ----
OTP_MOCK="true"            # MVP: código aparece no log. Trocar por Twilio/Zenvia depois.
OTP_TTL_SECONDS=300

# ---- PSP (Bloco 3 — ainda não escolhido) ----
PSP_PROVIDER="mock"

# ============================================================
#  WEB (apps/web/.env.local)
# ============================================================
# URL do deploy da API na Vercel (sem /api no fim). Em dev: http://localhost:3001
NEXT_PUBLIC_API_URL="https://SEU-API.vercel.app"
