// Schema do Bloco 0 — Fundação. Alinhado a docs/04-data-model.md.
// Entidades de blocos posteriores (Order, Conversation, Review, Report,
// BusinessListing) serão adicionadas nos respectivos blocos.

generator client {
  provider      = "prisma-client-js"
  // native = dev local; rhel = runtime serverless da Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL = conexão "pooled" do Supabase (pgbouncer, porta 6543) — usada em runtime.
  // DIRECT_URL   = conexão direta (porta 5432) — usada por migrate/introspect.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  individual
  business
}

enum UserStatus {
  active
  blocked
}

enum ListingStatus {
  draft
  active
  paused
  sold
  archived
}

model User {
  id              String     @id @default(uuid())
  name            String
  email           String     @unique
  emailVerified   Boolean    @default(false)
  phone           String     @unique
  phoneCountry    String     @default("BR")
  phoneVerified   Boolean    @default(false) // nível 1 — antifake (OTP)
  locale          String     @default("pt")
  country         String?
  avatarUrl       String? // obrigatório no onboarding (regra de app, não de banco)
  instagramHandle String? // prova social — exibido
  cpf             String? // nullable; só vendedor BR com payout PIX
  payoutAccountId String? // id da conta no PSP
  role            UserRole   @default(individual)
  status          UserStatus @default(active)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  listings Listing[]

  buyerConversations  Conversation[] @relation("buyerConvos")
  sellerConversations Conversation[] @relation("sellerConvos")
  messages            Message[]

  @@index([phone])
}

// Código OTP enviado por SMS (1 telefone = 1 conta).
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String // nunca guardamos o código em texto puro
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

// Define quais atributos cada categoria exige (kite -> size_m2, ano; etc.)
model Category {
  id              String   @id @default(uuid())
  slug            String   @unique
  namePt          String
  nameEn          String
  attributeSchema Json // JSON Schema dos atributos obrigatórios
  createdAt       DateTime @default(now())

  models   Model[]
  listings Listing[]
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  models   Model[]
  listings Listing[]
}

model Model {
  id         String   @id @default(uuid())
  name       String
  brandId    String
  categoryId String?
  createdAt  DateTime @default(now())

  brand    Brand     @relation(fields: [brandId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  listings Listing[]

  @@unique([brandId, name])
}

model Listing {
  id              String        @id @default(uuid())
  userId          String
  categoryId      String
  brandId         String?
  modelId         String?
  year            Int?
  attributes      Json          @default("{}") // validado contra Category.attributeSchema
  title           String
  description     String?
  price           Int // centavos
  city            String
  spot            String?
  shippable       Boolean       @default(false)
  status          ListingStatus @default(draft)
  soldToUserId    String?
  lastConfirmedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  user          User           @relation(fields: [userId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  brand         Brand?         @relation(fields: [brandId], references: [id])
  model         Model?         @relation(fields: [modelId], references: [id])
  images        ListingImage[]
  conversations Conversation[]

  @@index([categoryId])
  @@index([city])
  @@index([status])
  @@index([attributes], type: Gin) // busca por tamanho etc.
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

enum ConversationStatus {
  open
  archived
  blocked
}

// Conversa atrelada a um anúncio: 1 comprador + 1 vendedor.
model Conversation {
  id        String             @id @default(uuid())
  listingId String
  buyerId   String
  sellerId  String
  status    ConversationStatus @default(open)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("buyerConvos", fields: [buyerId], references: [id])
  seller   User      @relation("sellerConvos", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId]) // 1 conversa por comprador por anúncio
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  imageUrl       String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
}
