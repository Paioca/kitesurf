# ============================================================
#  Kitetropos — app único (apps/web/.env)
#  Next.js (App Router + API routes) + Supabase. Não há mais API separada.
# ============================================================

# ---- Banco (Supabase) ----
# Supabase > Project Settings > Database > Connection string.
# DATABASE_URL = "Transaction pooler" (porta 6543, com ?pgbouncer=true) — runtime.
# DIRECT_URL   = "Direct connection" (porta 5432) — migrations.
DATABASE_URL="postgresql://postgres.PROJ:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJ:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# ---- Supabase Storage (imagens) ----
# Supabase > Project Settings > API.
SUPABASE_URL="https://PROJ.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."   # SECRETO — só no backend
SUPABASE_BUCKET="listings"                          # bucket PÚBLICO com esse nome

# ---- Sessão (JWT) ----
# OBRIGATÓRIO e FORTE em produção (>= 32 chars aleatórios) — o app se recusa a
# subir em prod sem isso. Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="troque-por-32+-chars-aleatorios"
JWT_EXPIRES_IN="30d"

# ---- OTP / SMS (Twilio) ----
# OTP_MOCK=true (só fora de produção): código aparece no log, sem SMS. Em produção
# é ignorado — login exige SMS real via Twilio.
OTP_MOCK="true"
OTP_TTL_SECONDS=300
# SENTRY_DEV / números de teste só valem fora de produção.
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."          # SECRETO
TWILIO_SMS_FROM="+1..."          # remetente SMS
# WhatsApp (opcional, pra notificar vendedor de pedido novo):
# TWILIO_WHATSAPP_FROM="whatsapp:+55..."
# TWILIO_CONTENT_SID="HX..."     # template UTILITY aprovado

# ---- Observabilidade (Sentry) ----
NEXT_PUBLIC_SENTRY_DSN="https://...@oXXXX.ingest.us.sentry.io/XXXX"
# SENTRY_ORG="kite-tropos"
# SENTRY_PROJECT="<slug>"        # p/ upload de source maps
# SENTRY_AUTH_TOKEN="..."        # SECRETO — só no build/CI
# SENTRY_DEV="true"              # liga o Sentry em dev (default: só em prod)

# ---- Geral ----
APP_URL="https://kitetropos.com"  # base usada em links de notificação
PSP_PROVIDER="mock"               # pagamento não implementado (Fase 0)
