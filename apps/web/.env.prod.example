# ==========================================================================
# .env.prod.example  —  APENAS REFERÊNCIA DE NOMES DE VARIÁVEIS
# ==========================================================================
# A FONTE DE VERDADE dos valores de PRODUÇÃO é o painel do Vercel
# (Project Settings -> Environment Variables -> Production).
#
# NÃO recrie um arquivo .env.prod com valores reais neste repositório.
# Fazer `source .env.prod` com credenciais de prod pode disparar o
# circuit breaker do Supabase. Para inspecionar o ambiente use
# `vercel env pull` em um arquivo temporário e apague-o depois.
#
# Este arquivo lista só os NOMES esperados. Sem valores.
# ==========================================================================

# --- App / URLs ---
APP_URL=
NEXT_PUBLIC_API_URL=
API_PORT=

# --- Banco (Supabase / Postgres) ---
# DATABASE_URL usa o pooler (pgbouncer); DIRECT_URL usa a conexão direta (5432).
DATABASE_URL=
DIRECT_URL=

# --- Supabase (storage / service role) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=

# --- Auth / JWT ---
JWT_SECRET=
# JWT_SECRETS = lista para janela de aceitação de tokens legados na rotação.
JWT_SECRETS=
JWT_EXPIRES_IN=

# --- OTP ---
OTP_MOCK=
OTP_TTL_SECONDS=

# --- Cron ---
CRON_SECRET=

# --- Pagamentos (Fase 0 = sem PSP real) ---
PSP_PROVIDER=

# --- Notificações: SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# --- Notificações: e-mail (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=

# --- KV / Redis ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
REDIS_URL=

# --- Observabilidade (Sentry / Logtail / Better Stack) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
LOGTAIL_URL=
LOGTAIL_SOURCE_TOKEN=
NEXT_PUBLIC_LOGTAIL_SOURCE_TOKEN=
NEXT_PUBLIC_BETTER_STACK_INGESTING_URL=
NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=

# Nota: variáveis injetadas automaticamente pelo Vercel/Turbo/Nx no build
# (VERCEL_*, TURBO_*, NX_DAEMON, VERCEL_OIDC_TOKEN, etc.) NÃO precisam ser
# configuradas manualmente e por isso não aparecem aqui.
